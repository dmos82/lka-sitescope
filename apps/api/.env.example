# LKA SiteScope API — Environment Variables
# Copy to .env and fill in values

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/lkasitescope

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
BCRYPT_ROUNDS=10

# ─── Ports ────────────────────────────────────────────────────────────────────
PORT=4100
FRONTEND_URL=http://localhost:3100

# ─── External APIs ────────────────────────────────────────────────────────────
# US Census Bureau (optional — works without key for limited requests)
CENSUS_API_KEY=

# OpenRouteService (required for real drive-time isochrones)
ORS_API_KEY=

# Nominatim contact email (required per OSM usage policy)
NOMINATIM_CONTACT_EMAIL=contact@yourcompany.com

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ─── Node ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
