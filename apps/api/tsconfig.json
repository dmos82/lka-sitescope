{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "./dist",
    "declaration": false,
    "declarationMap": false,
    "paths": {
      "@lka/shared": ["../../packages/shared/src/index.ts"],
      "@lka/database": ["../../packages/database/src/index.ts"]
    }
  },
  "include": ["src/**/*", "../../packages/shared/src/**/*", "../../packages/database/src/**/*"],
  "exclude": ["node_modules", "dist"]
}
